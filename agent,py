def _load_dataframe(filepath: Path) -> pd.DataFrame:
    ext = filepath.suffix.lower()
    if ext == ".csv":
        return pd.read_csv(filepath, low_memory=False)
    if ext in (".xlsx", ".xls"):
        return pd.read_excel(filepath)
    if ext == ".parquet":
        return pd.read_parquet(filepath)
    if ext == ".json":
        raw = filepath.read_text(encoding="utf-8", errors="replace")
        obj = json.loads(raw)
        if isinstance(obj, list):
            return pd.json_normalize(obj)
        if isinstance(obj, dict):
            for v in obj.values():
                if isinstance(v, list):
                    return pd.json_normalize(v)
        return pd.DataFrame([obj])
    raise ValueError(f"Unsupported extension for DataFrame load: {ext}")


def _dataframe_to_prompt_summary(df: pd.DataFrame, max_rows: int = 40) -> str:
    buf = io.StringIO()
    buf.write(f"Shape: {df.shape[0]} rows × {df.shape[1]} columns\n")
    buf.write(f"Columns: {list(df.columns)}\n\n")

    buf.write("--- Data types ---\n")
    buf.write(df.dtypes.to_string() + "\n\n")

    buf.write("--- Missing values (count | %) ---\n")
    missing = df.isnull().sum()
    missing_pct = (missing / len(df) * 100).round(2)
    buf.write(pd.concat([missing, missing_pct], axis=1, keys=["count", "%"]).to_string() + "\n\n")

    buf.write("--- Descriptive statistics ---\n")
    buf.write(df.describe(include="all").to_string() + "\n\n")

    numeric_cols = df.select_dtypes(include="number").columns.tolist()
    if len(numeric_cols) >= 2:
        buf.write("--- Correlation matrix (numeric columns) ---\n")
        buf.write(df[numeric_cols].corr().round(3).to_string() + "\n\n")

    buf.write(f"--- Sample rows (first {min(max_rows, len(df))}) ---\n")
    buf.write(df.head(max_rows).to_string() + "\n")

    return buf.getvalue()


def _read_text_file(filepath: Path) -> str:
    return filepath.read_text(encoding="utf-8", errors="replace")[:30_000]


def load_file(filepath: Path) -> tuple[pd.DataFrame | None, str, str]:
    ext = filepath.suffix.lower()
    tabular_exts = {".csv", ".xlsx", ".xls", ".parquet", ".json"}

    if ext in tabular_exts:
        try:
            df = _load_dataframe(filepath)
            summary = _dataframe_to_prompt_summary(df)
            return df, summary, "tabular"
        except Exception as exc:
            raise RuntimeError(f"Could not load tabular file: {exc}") from exc

    raw = _read_text_file(filepath)
    return None, raw, "text"


