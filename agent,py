def analyse_file(filepath: Path, agent_id: str, client: OpenAI):
    filename = filepath.name
    log.info(f"[{agent_id}] Starting analysis of '{filename}'")
    STATE.update_agent(agent_id, status="loading", file=filename)

    try:
        df, data_summary, data_type = load_file(filepath)
    except RuntimeError as exc:
        _fail_agent(agent_id, filepath, str(exc))
        return

    STATE.update_agent(agent_id, status="analysing")
    STATE.log_agent_progress(agent_id, f"Data loaded ({data_type}), requesting analysis plan from NIM API")

    messages = [
        {"role": "system", "content": CONFIG["system_prompt"]},
        {"role": "user",   "content": f"Filename: {filename}\nData type: {data_type}\n\n=== DATA SUMMARY ===\n{data_summary}"},
    ]

    try:
        raw_response = nim_chat_with_retry(client, messages, agent_id)
    except Exception as exc:
        _fail_agent(agent_id, filepath, f"API failure after all retries: {exc}")
        return

    STATE.log_agent_progress(agent_id, "Analysis plan received. Parsing JSON.")

    try:
        clean = re.sub(r"^```(?:json)?\s*", "", raw_response.strip(), flags=re.IGNORECASE)
        clean = re.sub(r"\s*```$", "", clean.strip())
        plan  = json.loads(clean)
    except json.JSONDecodeError:
        log.warning(f"[{agent_id}] JSON parse failed — using fallback plan.")
        plan = {
            "title":             filename,
            "executive_summary": raw_response[:500],
            "findings":          [{"number": 1, "heading": "Raw Analysis", "detail": raw_response}],
            "recommendations":   [],
            "data_quality":      {"issues": [], "completeness_pct": None},
            "charts":            [],
            "derived_columns":   [],
            "highlight_rules":   [],
        }

    STATE.update_agent(agent_id, status="building report")
    STATE.log_agent_progress(agent_id, "Building Excel workbook with charts and formatting.")

    tmp_dir = CONFIG["results_dir"] / f"_tmp_{agent_id}"
    tmp_dir.mkdir(exist_ok=True)
    try:
        out_path = build_excel_report(df, plan, filepath, agent_id, tmp_dir)
    except Exception as exc:
        _fail_agent(agent_id, filepath, f"Excel build failed: {exc}\n{traceback.format_exc()}")
        return
    finally:
        shutil.rmtree(str(tmp_dir), ignore_errors=True)

    log.info(f"[{agent_id}] Report saved → '{out_path.name}'")
    ts   = datetime.utcnow().strftime("%Y%m%d_%H%M%S")
    dest = CONFIG["processed_dir"] / f"{filepath.stem}_{ts}{filepath.suffix}"
    shutil.move(str(filepath), str(dest))
    STATE.finish_agent(agent_id, success=True, summary=plan.get("executive_summary", "")[:400])
    log.info(f"[{agent_id}] Task complete for '{filename}'")


def _fail_agent(agent_id: str, filepath: Path, reason: str):
    log.error(f"[{agent_id}] FAILED: {reason}")
    STATE.log_agent_progress(agent_id, f"FAILED: {reason}")

    ts       = datetime.utcnow().strftime("%Y%m%d_%H%M%S")
    stem     = filepath.stem
    err_path = CONFIG["failed_dir"] / f"{stem}_{ts}_error.txt"
    err_path.write_text(
        f"Agent ID : {agent_id}\n"
        f"File     : {filepath.name}\n"
        f"Time     : {datetime.utcnow().isoformat()} UTC\n"
        f"Reason   : {reason}\n\n"
        f"{traceback.format_exc()}",
        encoding="utf-8",
    )
    dest = CONFIG["failed_dir"] / f"{stem}_{ts}{filepath.suffix}"
    try:
        shutil.move(str(filepath), str(dest))
    except Exception:
        pass

    STATE.finish_agent(agent_id, success=False, summary=reason[:400])


