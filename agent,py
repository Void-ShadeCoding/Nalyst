def _sheet_data(wb: Workbook, df: pd.DataFrame, plan: dict):
    ws = wb.create_sheet("Data")
    ws.freeze_panes = "A2"

    for d in plan.get("derived_columns", []):
        cols = d.get("source_cols", [])
        if len(cols) == 2 and all(c in df.columns for c in cols):
            try:
                c0, c1 = df[cols[0]], df[cols[1]]
                if pd.api.types.is_numeric_dtype(c0) and pd.api.types.is_numeric_dtype(c1):
                    df = df.copy()
                    df[d["name"]] = c0 / c1.replace(0, np.nan)
            except Exception:
                pass

    col_names = list(df.columns)
    _apply_header_row(ws, 1, col_names)
    ws.row_dimensions[1].height = 22

    for r_i, row in enumerate(df.itertuples(index=False), start=2):
        stripe = PALETTE["stripe"] if r_i % 2 == 0 else PALETTE["white"]
        for c_i, val in enumerate(row, start=1):
            cell = ws.cell(row=r_i, column=c_i)
            cell.value = None if (isinstance(val, float) and math.isnan(val)) else val
            cell.font  = _body_font()
            cell.fill  = _fill(stripe)
            cell.border = _thin_border()
            cell.alignment = Alignment(
                horizontal="right" if isinstance(val, (int, float)) else "left",
                vertical="center",
            )

    for c_i, col in enumerate(col_names, start=1):
        try:
            max_len = max(len(str(col)), df[col].astype(str).str.len().max() if len(df) else 0)
        except Exception:
            max_len = len(str(col))
        ws.column_dimensions[get_column_letter(c_i)].width = min(max(max_len + 2, 10), 40)

    _apply_highlights(ws, df, plan.get("highlight_rules", []), col_names)


def _apply_highlights(ws, df: pd.DataFrame, rules: list, col_names: list):
    for rule in rules:
        col_name   = rule.get("col")
        rule_type  = rule.get("rule")
        hex_col    = HIGHLIGHT_COLORS.get(rule.get("color", "orange"), HIGHLIGHT_COLORS["orange"])

        if col_name not in col_names or col_name not in df.columns:
            continue
        if not pd.api.types.is_numeric_dtype(df[col_name]):
            continue

        col_idx = col_names.index(col_name) + 1
        series  = df[col_name].dropna()
        try:
            if rule_type == "top10":
                flagged = df.index[df[col_name] >= series.quantile(0.90)].tolist()
            elif rule_type == "bottom10":
                flagged = df.index[df[col_name] <= series.quantile(0.10)].tolist()
            elif rule_type == "above_mean":
                flagged = df.index[df[col_name] > series.mean()].tolist()
            elif rule_type == "below_mean":
                flagged = df.index[df[col_name] < series.mean()].tolist()
            elif rule_type == "outlier":
                z       = np.abs(scipy_stats.zscore(series))
                flagged = series.index[z > 2.5].tolist()
            else:
                continue
            for idx in flagged:
                cell = ws.cell(row=idx + 2, column=col_idx)
                cell.fill = _fill(hex_col)
                cell.font = Font(name="Arial", size=10, bold=True,
                                 color="FFFFFF" if rule.get("color") in ("red", "blue") else "000000")
        except Exception:
            continue


def _make_chart_images(df: pd.DataFrame, plan: dict, tmp_dir: Path) -> list[Path]:
    sns.set_theme(style="whitegrid", palette="muted")
    image_paths = []

    for i, spec in enumerate(plan.get("charts", [])):
        chart_type = spec.get("type", "bar")
        title      = spec.get("title", f"Chart {i + 1}")
        x_col      = spec.get("x_col") if spec.get("x_col") in df.columns else None
        y_col      = spec.get("y_col") if spec.get("y_col") in df.columns else None
        numeric_cols = df.select_dtypes(include="number").columns.tolist()

        try:
            fig, ax = plt.subplots(figsize=(9, 4.5))
            fig.patch.set_facecolor("#F8FAFC")
            ax.set_facecolor("#F8FAFC")
            plotted = False

            if chart_type == "histogram" and (y_col or numeric_cols):
                target = y_col or numeric_cols[0]
                ax.hist(df[target].dropna(), bins=30, color="#3498DB", edgecolor="white", alpha=0.85)
                ax.set_xlabel(target, fontsize=10)
                ax.set_ylabel("Frequency", fontsize=10)
                plotted = True

            elif chart_type == "scatter" and x_col and y_col:
                xd = pd.to_numeric(df[x_col], errors="coerce")
                yd = pd.to_numeric(df[y_col], errors="coerce")
                mask = xd.notna() & yd.notna()
                ax.scatter(xd[mask], yd[mask], alpha=0.55, color="#E94560",
                           edgecolors="white", linewidth=0.5)
                ax.set_xlabel(x_col, fontsize=10)
                ax.set_ylabel(y_col, fontsize=10)
                plotted = True

            elif chart_type == "pie" and (x_col or y_col):
                cat_col = x_col or (df.select_dtypes("object").columns[0]
                                    if len(df.select_dtypes("object").columns) else None)
                val_col = y_col or (numeric_cols[0] if numeric_cols else None)
                if cat_col and val_col:
                    grouped = df.groupby(cat_col)[val_col].sum().nlargest(8)
                    ax.pie(grouped.values, labels=grouped.index,
                           autopct="%1.1f%%", colors=plt.cm.Set2.colors, startangle=140)
                    plotted = True

            elif chart_type == "line" and y_col:
                yd   = pd.to_numeric(df[y_col], errors="coerce")
                xd   = pd.to_numeric(df[x_col], errors="coerce") if x_col else pd.Series(range(len(df)))
                mask = yd.notna()
                ax.plot(xd[mask].values, yd[mask].values, color="#2ECC71", linewidth=2)
                if x_col:
                    ax.set_xlabel(x_col, fontsize=10)
                ax.set_ylabel(y_col, fontsize=10)
                plotted = True

            if not plotted:
                if y_col and x_col:
                    grouped = df.groupby(x_col)[y_col].mean().nlargest(15)
                    grouped.plot(kind="bar", ax=ax, color="#16213E", edgecolor="white")
                    ax.set_xlabel(x_col, fontsize=10)
                    ax.set_ylabel(y_col, fontsize=10)
                    plt.xticks(rotation=35, ha="right", fontsize=8)
                    plotted = True
                elif numeric_cols:
                    df[numeric_cols[:1]].plot(kind="bar", ax=ax, color="#16213E", edgecolor="white")
                    plt.xticks(rotation=35, ha="right", fontsize=8)
                    plotted = True

            if not plotted:
                plt.close(fig)
                continue

            ax.set_title(title, fontsize=12, fontweight="bold", color="#1A1A2E", pad=14)
            for spine in ax.spines.values():
                spine.set_color("#BDC3C7")
            ax.tick_params(colors="#555555", labelsize=9)
            plt.tight_layout()

            img_path = tmp_dir / f"chart_{i:02d}.png"
            fig.savefig(str(img_path), dpi=130, bbox_inches="tight",
                        facecolor=fig.get_facecolor())
            plt.close(fig)
            image_paths.append(img_path)

        except Exception as exc:
            log.warning(f"Chart '{title}' failed: {exc}")
            plt.close("all")

    return image_paths


def _sheet_charts(wb: Workbook, image_paths: list[Path], plan: dict):
    if not image_paths:
        return
    ws = wb.create_sheet("Charts")
    ws.sheet_view.showGridLines = False
    ws.column_dimensions["A"].width = 2
    chart_specs = plan.get("charts", [])
    row = 2

    for idx, img_path in enumerate(image_paths):
        try:
            spec  = chart_specs[idx] if idx < len(chart_specs) else {}
            title = spec.get("title", f"Chart {idx + 1}")
            rat   = spec.get("rationale", "")

            title_cell = ws.cell(row=row, column=2, value=title)
            title_cell.font      = Font(name="Arial", size=12, bold=True, color=PALETTE["accent2"])
            title_cell.alignment = Alignment(vertical="center")
            ws.row_dimensions[row].height = 20
            row += 1

            if rat:
                rc = ws.cell(row=row, column=2, value=f"Insight: {rat}")
                rc.font = Font(name="Arial", size=9, italic=True, color="777777")
                rc.alignment = Alignment(wrap_text=True)
                ws.row_dimensions[row].height = 14
                row += 1

            img = XLImage(str(img_path))
            img.anchor = f"B{row}"
            ws.add_image(img)
            row += 23
        except Exception as exc:
            log.warning(f"Could not embed chart {img_path.name}: {exc}")


def _sheet_statistics(wb: Workbook, df: pd.DataFrame):
    ws = wb.create_sheet("Statistics")
    ws.sheet_view.showGridLines = False
    ws.column_dimensions["A"].width = 5

    numeric_df = df.select_dtypes(include="number")
    if numeric_df.empty:
        ws.cell(row=2, column=2, value="No numeric columns found.")
        return

    stats_df = numeric_df.describe(percentiles=[.1, .25, .5, .75, .9]).T
    stats_df["skew"]     = numeric_df.skew()
    stats_df["kurtosis"] = numeric_df.kurtosis()
    stats_df = stats_df.reset_index().rename(columns={"index": "Column"})

    _apply_header_row(ws, 1, [""] + list(stats_df.columns), bg=PALETTE["accent2"])
    ws.row_dimensions[1].height = 22
    ws.column_dimensions["B"].width = 3

    for r_i, row in enumerate(stats_df.itertuples(index=False), start=2):
        stripe = PALETTE["stripe"] if r_i % 2 == 0 else PALETTE["white"]
        for c_i, val in enumerate(row, start=3):
            cell = ws.cell(row=r_i, column=c_i)
            if isinstance(val, float):
                cell.value         = round(val, 4)
                cell.number_format = "0.0000"
                cell.alignment     = Alignment(horizontal="right", vertical="center")
            else:
                cell.value     = val
                cell.alignment = Alignment(vertical="center")
            cell.font   = _body_font()
            cell.fill   = _fill(stripe)
            cell.border = _thin_border()
        name_cell       = ws.cell(row=r_i, column=3, value=str(row[0]))
        name_cell.font  = _body_font(bold=True, color=PALETTE["accent2"])
        name_cell.fill  = _fill(stripe)
        name_cell.border= _thin_border()

    for c_i in range(3, len(stats_df.columns) + 3):
        ws.column_dimensions[get_column_letter(c_i)].width = 14

    if len(numeric_df.columns) >= 2:
        corr_row = len(stats_df) + 4
        ws.cell(row=corr_row, column=3, value="Correlation Matrix").font = \
            _header_font(size=12, color=PALETTE["header_bg"])
        ws.row_dimensions[corr_row].height = 20
        corr = numeric_df.corr().round(3)

        for c_i, lbl in enumerate(corr.columns, start=4):
            cell = ws.cell(row=corr_row + 1, column=c_i, value=lbl)
            cell.font  = _header_font(size=9)
            cell.fill  = _fill(PALETTE["accent2"])
            cell.alignment = Alignment(horizontal="center", vertical="center", wrap_text=True)
            ws.column_dimensions[get_column_letter(c_i)].width = 12

        for r_i, (row_label, row_vals) in enumerate(corr.iterrows()):
            excel_row = corr_row + 2 + r_i
            lc = ws.cell(row=excel_row, column=3, value=row_label)
            lc.font  = _body_font(bold=True, color=PALETTE["accent2"])
            lc.fill  = _fill(PALETTE["stripe"])
            for c_i, val in enumerate(row_vals, start=4):
                cell = ws.cell(row=excel_row, column=c_i, value=val)
                cell.number_format = "0.000"
                cell.alignment     = Alignment(horizontal="center", vertical="center")
                intensity = int(abs(val) * 180)
                hex_c = (f"{255 - intensity:02X}FF{255 - intensity:02X}" if val >= 0
                         else f"FF{255 - intensity:02X}{255 - intensity:02X}")
                cell.fill   = _fill(hex_c)
                cell.font   = _body_font(size=9)
                cell.border = _thin_border()


def _sheet_data_quality(wb: Workbook, df: pd.DataFrame, plan: dict):
    ws = wb.create_sheet("Data Quality")
    ws.sheet_view.showGridLines = False
    ws.column_dimensions["A"].width = 5
    ws.column_dimensions["B"].width = 30
    ws.column_dimensions["C"].width = 18
    ws.column_dimensions["D"].width = 18
    ws.column_dimensions["E"].width = 18

    ws.cell(row=1, column=2, value="Data Quality Report").font = \
        _header_font(size=14, color=PALETTE["header_bg"])
    ws.row_dimensions[1].height = 26

    dq = plan.get("data_quality", {})
    completeness = dq.get("completeness_pct")
    ws.cell(row=2, column=2, value="Overall Completeness").font = _body_font(bold=True)
    comp_cell = ws.cell(row=2, column=3, value=f"{completeness}%" if completeness else "N/A")
    comp_cell.font = Font(name="Arial", size=11, bold=True,
                          color=PALETTE["positive"] if completeness and completeness >= 90
                          else PALETTE["negative"])

    _apply_header_row(ws, 4, ["Column", "Non-Null", "Null Count", "Null %", "Dtype"],
                      bg=PALETTE["accent2"])
    for r_i, col in enumerate(df.columns):
        row     = 5 + r_i
        nn      = df[col].notna().sum()
        nc      = df[col].isna().sum()
        np_     = round(nc / len(df) * 100, 2) if len(df) else 0
        stripe  = PALETTE["stripe"] if r_i % 2 == 0 else PALETTE["white"]
        for c_i, v in enumerate([col, nn, nc, np_, str(df[col].dtype)], start=2):
            cell        = ws.cell(row=row, column=c_i, value=v)
            cell.font   = _body_font()
            cell.fill   = _fill(PALETTE["warning"] if c_i == 5 and np_ > 20 else stripe)
            cell.border = _thin_border()
            cell.alignment = Alignment(
                vertical="center",
                horizontal="right" if isinstance(v, (int, float)) else "left",
            )

    issues = dq.get("issues", [])
    if issues:
        iss = 6 + len(df.columns)
        ws.cell(row=iss, column=2, value="AI-Identified Issues").font = \
            _header_font(size=12, color=PALETTE["header_bg"])
        for j, issue in enumerate(issues):
            r = iss + 1 + j
            c = ws.cell(row=r, column=2, value=f"⚠  {issue}")
            c.font = _body_font(color=PALETTE["negative"])
            c.alignment = Alignment(wrap_text=True)
            ws.row_dimensions[r].height = 20


def build_excel_report(df: pd.DataFrame | None, plan: dict,
                       filepath: Path, agent_id: str, tmp_dir: Path) -> Path:
    wb = Workbook()
    _sheet_cover(wb, plan, filepath.name, agent_id)
    _sheet_findings(wb, plan)
    if df is not None and not df.empty:
        _sheet_data(wb, df, plan)
        _sheet_statistics(wb, df)
        _sheet_data_quality(wb, df, plan)
        image_paths = _make_chart_images(df, plan, tmp_dir)
        _sheet_charts(wb, image_paths, plan)
    else:
        ws_txt = wb.create_sheet("Content")
        ws_txt.cell(row=1, column=1, value="Non-tabular source — see Findings sheet.")
    ts       = datetime.utcnow().strftime("%Y%m%d_%H%M%S")
    out_path = CONFIG["results_dir"] / f"{filepath.stem}_{ts}_analysis.xlsx"
    wb.save(str(out_path))
    return out_path


