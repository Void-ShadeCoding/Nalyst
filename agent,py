def _thin_border() -> Border:
    s = Side(style="thin", color=PALETTE["border_col"])
    return Border(left=s, right=s, top=s, bottom=s)

def _header_font(size: int = 11, bold: bool = True, color: str = None) -> Font:
    return Font(name="Arial", bold=bold, size=size, color=color or PALETTE["header_fg"])

def _body_font(size: int = 10, bold: bool = False, color: str = "000000") -> Font:
    return Font(name="Arial", size=size, bold=bold, color=color)

def _fill(hex_color: str) -> PatternFill:
    return PatternFill("solid", fgColor=hex_color)

def _apply_header_row(ws, row: int, labels: list, bg: str = None):
    bg = bg or PALETTE["header_bg"]
    for col_i, label in enumerate(labels, 1):
        cell = ws.cell(row=row, column=col_i, value=label)
        cell.font      = _header_font()
        cell.fill      = _fill(bg)
        cell.alignment = Alignment(horizontal="center", vertical="center", wrap_text=True)
        cell.border    = _thin_border()


