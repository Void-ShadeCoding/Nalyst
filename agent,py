  const h = Math.floor(u/3600), m2 = Math.floor((u%3600)/60), sec = Math.floor(u%60);
  document.getElementById('uptime').textContent =
    'Uptime: '+String(h).padStart(2,'0')+':'+String(m2).padStart(2,'0')+':'+String(sec).padStart(2,'0');

