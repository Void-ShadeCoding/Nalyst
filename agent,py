def build_nim_client() -> OpenAI:
    key = CONFIG["nim_api_key"]
    if not key:
        log.critical("NIM_API_KEY is not set. Export it or set it in CONFIG.")
        sys.exit(1)
    return OpenAI(api_key=key, base_url=CONFIG["nim_base_url"])


def nim_chat_with_retry(client: OpenAI, messages: list, agent_id: str) -> str:
    backoff = CONFIG["initial_backoff_seconds"]
    for attempt in range(1, CONFIG["max_retries"] + 1):
        try:
            STATE.log_agent_progress(agent_id, f"API call attempt {attempt}")
            response = client.chat.completions.create(
                model=CONFIG["nim_model"],
                messages=messages,
                max_tokens=CONFIG["max_tokens"],
                temperature=CONFIG["temperature"],
            )
            return response.choices[0].message.content
        except Exception as exc:
            err = str(exc)
            log.warning(f"[{agent_id}] API error on attempt {attempt}: {err}")
            STATE.log_agent_progress(agent_id, f"API error (attempt {attempt}): {err}")
            if attempt == CONFIG["max_retries"]:
                raise
            sleep_for = min(backoff, CONFIG["max_backoff_seconds"])
            log.info(f"[{agent_id}] Backing off {sleep_for}s before retry {attempt + 1}")
            time.sleep(sleep_for)
            backoff *= CONFIG["backoff_multiplier"]
    raise RuntimeError("Exhausted all retries")


