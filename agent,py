class AgentState:
    """Thread-safe shared state for agents and dashboard."""

    def __init__(self):
        self._lock = threading.Lock()
        self.active_agents: dict[str, dict] = {}
        self.completed_tasks: deque = deque(maxlen=200)
        self.metrics_history: deque = deque(maxlen=CONFIG["metrics_history_len"])
        self.total_tasks_completed = 0
        self.total_tasks_failed = 0
        self.startup_time = datetime.utcnow()

    def add_agent(self, agent_id: str, filename: str):
        with self._lock:
            self.active_agents[agent_id] = {
                "id": agent_id,
                "file": filename,
                "status": "starting",
                "started_at": datetime.utcnow().isoformat(),
                "progress_log": [],
            }

    def update_agent(self, agent_id: str, **kwargs):
        with self._lock:
            if agent_id in self.active_agents:
                self.active_agents[agent_id].update(kwargs)

    def log_agent_progress(self, agent_id: str, message: str):
        with self._lock:
            if agent_id in self.active_agents:
                self.active_agents[agent_id]["progress_log"].append(
                    {"time": datetime.utcnow().isoformat(), "msg": message}
                )

    def finish_agent(self, agent_id: str, success: bool, summary: str = ""):
        with self._lock:
            agent = self.active_agents.pop(agent_id, None)
            if agent:
                agent["status"] = "completed" if success else "failed"
                agent["finished_at"] = datetime.utcnow().isoformat()
                agent["summary"] = summary
                self.completed_tasks.appendleft(agent)
                if success:
                    self.total_tasks_completed += 1
                else:
                    self.total_tasks_failed += 1

    def snapshot(self) -> dict:
        with self._lock:
            return {
                "active_agents": list(self.active_agents.values()),
                "completed_tasks": list(self.completed_tasks),
                "total_completed": self.total_tasks_completed,
                "total_failed": self.total_tasks_failed,
                "uptime_seconds": (datetime.utcnow() - self.startup_time).total_seconds(),
            }


