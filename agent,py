def main():
    log.info("=" * 60)
    log.info("  NVIDIA NIM AI Data Analysis Agent  ")
    log.info("=" * 60)

    client = build_nim_client()
    log.info(f"NIM client ready — model: {CONFIG['nim_model']}")

    task_queue: list  = []
    queue_lock        = threading.Lock()

    scan_inbox_on_startup(task_queue, queue_lock)

    observer = Observer()
    handler  = InboxWatcher(task_queue, queue_lock)
    observer.schedule(handler, str(CONFIG["inbox_dir"]), recursive=False)
    observer.start()
    log.info(f"Watching inbox: {CONFIG['inbox_dir'].resolve()}")

    dispatch_thread = threading.Thread(
        target=dispatch_loop,
        args=(task_queue, queue_lock, client),
        daemon=True,
        name="dispatcher",
    )
    dispatch_thread.start()

    app = Flask(__name__)
    app.config["SECRET_KEY"] = ""
    
    socketio = SocketIO(app, cors_allowed_origins="*", async_mode="threading")
    setup_dashboard_routes(app)

    metrics_thread = threading.Thread(
        target=metrics_loop,
        args=(socketio,),
        daemon=True,
        name="metrics",
    )
    metrics_thread.start()

    def _shutdown(sig, frame):
        log.info("Shutdown signal received. Stopping watcher...")
        observer.stop()
        observer.join()
        sys.exit(0)

    signal.signal(signal.SIGINT,  _shutdown)
    signal.signal(signal.SIGTERM, _shutdown)

    log.info(f"Dashboard available at: http://0.0.0.0:{CONFIG['dashboard_port']}")
    log.info("Drop files into ./data/inbox/ to begin analysis.")

    socketio.run(
        app,
        host=CONFIG["dashboard_host"],
        port=CONFIG["dashboard_port"],
        use_reloader=False,
        log_output=False,
        allow_unsafe_werkzeug=True,
    )


if __name__ == "__main__":
    main()
