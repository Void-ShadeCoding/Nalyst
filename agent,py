class InboxWatcher(FileSystemEventHandler):
    def __init__(self, queue: list, queue_lock: threading.Lock):
        self.queue      = queue
        self.queue_lock = queue_lock
        self._seen: set = set()

    def on_created(self, event):
        if not event.is_directory:
            self._enqueue(Path(event.src_path))

    def _enqueue(self, path: Path):
        if path.suffix.lower() not in CONFIG["supported_extensions"]:
            return
        fid = hashlib.md5(str(path).encode()).hexdigest()
        with self.queue_lock:
            if fid not in self._seen:
                self._seen.add(fid)
                self.queue.append(path)
                log.info(f"Queued: {path.name}")


def dispatch_loop(queue: list, queue_lock: threading.Lock, client: OpenAI):
    semaphore = threading.Semaphore(CONFIG["max_concurrent_agents"])

    def run_agent(path: Path):
        with semaphore:
            agent_id = str(uuid.uuid4())[:8]
            STATE.add_agent(agent_id, path.name)
            try:
                analyse_file(path, agent_id, client)
            except Exception as exc:
                log.error(f"[{agent_id}] Unhandled exception: {exc}")
                STATE.finish_agent(agent_id, success=False, summary=str(exc))

    while True:
        with queue_lock:
            batch = queue.copy()
            queue.clear()

        for path in batch:
            if not path.exists():
                continue
            t = threading.Thread(target=run_agent, args=(path,), daemon=True)
            t.start()

        if not batch:
            time.sleep(CONFIG["poll_interval_seconds"])


def scan_inbox_on_startup(queue: list, queue_lock: threading.Lock):
    for path in CONFIG["inbox_dir"].iterdir():
        if path.is_file() and path.suffix.lower() in CONFIG["supported_extensions"]:
            with queue_lock:
                queue.append(path)
            log.info(f"Found existing file at startup: {path.name}")


