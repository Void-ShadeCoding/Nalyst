  "dataset_title": "Title",
  "description":   "Scope of dataset",
  "columns": [{"name": "col_name", "description": "...", "type": "string|number|url|email|date"}],
  "seed_urls": ["https://...", ...],
  "search_queries": ["query to find relevant pages", ...],
  "extraction_hints": "What to look for on each page (emails, phone numbers, addresses, etc.)",
  "notes": "Caveats"
}

Rules:
- seed_urls: real, likely-valid starting URLs (business directories, government sites, etc.)
- search_queries: 3-8 targeted queries a human researcher would use
- Be specific about what data to extract per page
- Limit seed_urls to 20 maximum"""


def _search_duckduckgo(query: str, session: requests.Session, max_results: int = 10) -> list[str]:
    try:
        params = {"q": query, "format": "json", "no_html": "1", "skip_disambig": "1"}
        resp   = session.get("https://api.duckduckgo.com/", params=params, timeout=10)
        data   = resp.json()
        urls   = []
        for item in data.get("Results", []) + data.get("RelatedTopics", []):
            if isinstance(item, dict):
                url = item.get("FirstURL", "")
                if url and url.startswith("http"):
                    urls.append(url)
        return urls[:max_results]
    except Exception as exc:
        log.warning(f"DuckDuckGo search error: {exc}")
        return []


def _scrape_urls_for_dataset(urls: list[str], columns: list[dict],
                              extraction_hints: str,
                              session: requests.Session,
                              client: OpenAI,
                              agent_id: str) -> list[dict]:
    rows = []
    col_names = [c["name"] for c in columns]

    def scrape_and_extract(url: str) -> list[dict]:
        try:
            text, final_url = _fetch_page(url, session)
            if not text:
                return []
            prompt = (
                f"Extract structured data from this webpage text. "
                f"Return ONLY a JSON array of objects. Each object must have these keys: {col_names}. "
                f"Extraction focus: {extraction_hints}\n\nURL: {final_url}\n\nPAGE TEXT:\n{text[:8000]}"
            )
            raw = client.chat.completions.create(
                model=CONFIG["nim_model"],
                messages=[{"role": "user", "content": prompt}],
                max_tokens=2000,
                temperature=0.1,
            ).choices[0].message.content
            clean = re.sub(r"^```(?:json)?\s*", "", raw.strip(), flags=re.IGNORECASE)
            clean = re.sub(r"\s*```$", "", clean.strip())
            parsed = json.loads(clean)
            if isinstance(parsed, list):
                return parsed
            if isinstance(parsed, dict):
                return [parsed]
        except Exception as exc:
            log.warning(f"[{agent_id}] Extract error for {url}: {exc}")
        return []

    total = len(urls)
    with concurrent.futures.ThreadPoolExecutor(max_workers=CONFIG["scraper_max_workers"]) as pool:
        futures = {pool.submit(scrape_and_extract, u): u for u in urls}
        for i, future in enumerate(concurrent.futures.as_completed(futures)):
            try:
                extracted = future.result()
                rows.extend(extracted)
            except Exception as exc:
                log.warning(f"[{agent_id}] Future error: {exc}")
            STATE.log_agent_progress(agent_id, f"Processed page {i+1}/{total} — {len(rows)} rows so far")

    return rows


def run_dataset_generation(prompt: str, agent_id: str, client: OpenAI,
                            use_scraping: bool = False) -> Path:
    STATE.log_agent_progress(agent_id, "Planning dataset structure with NIM API")

    if use_scraping:
        system = DATASET_SCRAPE_SYSTEM
    else:
        system = DATASET_GEN_SYSTEM

    raw = nim_chat_with_retry(
        client,
        [{"role": "system", "content": system},
         {"role": "user",   "content": prompt}],
        agent_id,
    )

    try:
        clean = re.sub(r"^```(?:json)?\s*", "", raw.strip(), flags=re.IGNORECASE)
        clean = re.sub(r"\s*```$", "", clean.strip())
        plan  = json.loads(clean)
    except Exception:
        raise RuntimeError(f"NIM API returned invalid JSON for dataset plan: {raw[:300]}")

    columns = plan.get("columns", [])
    rows    = plan.get("rows", [])
    session = _build_http_session()

    if use_scraping:
        STATE.log_agent_progress(agent_id, "Scraping seed URLs and search results")
        all_urls = list(plan.get("seed_urls", []))
        for query in plan.get("search_queries", [])[:5]:
            found = _search_duckduckgo(query, session, max_results=8)
            all_urls.extend(found)
        all_urls = list(dict.fromkeys(all_urls))[:40]

        extraction_hints = plan.get("extraction_hints", "Extract all relevant structured data")
        rows = _scrape_urls_for_dataset(all_urls, columns, extraction_hints,
                                         session, client, agent_id)

        if not rows and plan.get("columns"):
            STATE.log_agent_progress(agent_id, "Scraping yielded no rows — falling back to AI generation")
            fallback_raw = nim_chat_with_retry(
                client,
                [{"role": "system", "content": DATASET_GEN_SYSTEM},
                 {"role": "user",   "content": prompt}],
                agent_id,
            )
            try:
                fb_clean = re.sub(r"^```(?:json)?\s*", "", fallback_raw.strip(), flags=re.IGNORECASE)
                fb_clean = re.sub(r"\s*```$", "", fb_clean.strip())
                fb_plan  = json.loads(fb_clean)
                rows     = fb_plan.get("rows", [])
                columns  = fb_plan.get("columns", columns)
            except Exception:
                pass

    if not rows:
        raise RuntimeError("Dataset generation produced zero rows.")

    df = pd.DataFrame(rows)
    if not df.empty:
        for col_info in columns:
            cname = col_info.get("name")
            ctype = col_info.get("type", "string")
            if cname in df.columns:
                if ctype == "number":
                    df[cname] = pd.to_numeric(df[cname], errors="coerce")

    ts       = datetime.utcnow().strftime("%Y%m%d_%H%M%S")
    safe_title = re.sub(r"[^a-z0-9_]", "_", plan.get("dataset_title", "dataset").lower())[:40]

    csv_path  = CONFIG["generated_dir"] / f"{safe_title}_{ts}.csv"
    xlsx_path = CONFIG["generated_dir"] / f"{safe_title}_{ts}.xlsx"

    df.to_csv(str(csv_path), index=False, encoding="utf-8")

    wb = Workbook()
    cover = wb.active
    cover.title = "Info"
    cover.sheet_view.showGridLines = False
    cover.column_dimensions["A"].width = 4
    cover.column_dimensions["B"].width = 55

    def cov(row, text, size=12, bold=True, color=None):
        c = cover.cell(row=row, column=2, value=text)
        c.font = Font(name="Arial", size=size, bold=bold, color=color or PALETTE["header_bg"])
        c.alignment = Alignment(vertical="center")
        cover.row_dimensions[row].height = size * 1.9

    cov(1, plan.get("dataset_title", "Generated Dataset"), size=16)
    cov(2, plan.get("description", ""), size=10, bold=False, color="444444")
    cover.row_dimensions[3].height = 10
    for i, (k, v) in enumerate([
        ("Rows",        len(df)),
        ("Columns",     len(df.columns)),
        ("Generated",   datetime.utcnow().strftime("%Y-%m-%d %H:%M UTC")),
        ("Agent ID",    agent_id),
        ("Prompt",      prompt[:120] + ("..." if len(prompt) > 120 else "")),
    ], start=4):
        cover.cell(row=i, column=2, value=k).font  = Font(name="Arial", size=9, bold=True, color=PALETTE["accent2"])
        vc = cover.cell(row=i, column=3, value=str(v))
        vc.font = Font(name="Arial", size=9)
        cover.column_dimensions["C"].width = 40
        cover.row_dimensions[i].height = 14

    notes_row = 4 + 5 + 1
    cover.merge_cells(f"B{notes_row}:C{notes_row+4}")
    nc = cover.cell(row=notes_row, column=2, value=plan.get("notes", ""))
    nc.font      = Font(name="Arial", size=9, italic=True, color="666666")
    nc.alignment = Alignment(wrap_text=True, vertical="top")
    cover.row_dimensions[notes_row].height = 60

    ws = wb.create_sheet("Data")
    ws.freeze_panes = "A2"
    _apply_header_row(ws, 1, list(df.columns))
    ws.row_dimensions[1].height = 22
    for r_i, row in enumerate(df.itertuples(index=False), start=2):
        stripe = PALETTE["stripe"] if r_i % 2 == 0 else PALETTE["white"]
        for c_i, val in enumerate(row, start=1):
            cell = ws.cell(row=r_i, column=c_i)
            cell.value = None if (isinstance(val, float) and math.isnan(val)) else val
            cell.font  = _body_font()
            cell.fill  = _fill(stripe)
            cell.border = _thin_border()
            cell.alignment = Alignment(
                horizontal="right" if isinstance(val, (int, float)) else "left",
                vertical="center",
            )
    for c_i, col_name in enumerate(df.columns, start=1):
        try:
            max_len = max(len(col_name), df[col_name].astype(str).str.len().max() if len(df) else 0)
        except Exception:
            max_len = len(col_name)
        ws.column_dimensions[get_column_letter(c_i)].width = min(max(max_len + 2, 12), 45)

    col_map = wb.create_sheet("Column Info")
    col_map.sheet_view.showGridLines = False
    col_map.column_dimensions["A"].width = 4
    col_map.column_dimensions["B"].width = 28
    col_map.column_dimensions["C"].width = 16
    col_map.column_dimensions["D"].width = 55
    _apply_header_row(col_map, 1, ["", "Column", "Type", "Description"], bg=PALETTE["accent2"])
    for i, col_info in enumerate(columns):
        r = 2 + i
        stripe = PALETTE["stripe"] if i % 2 == 0 else PALETTE["white"]
        col_map.cell(row=r, column=2, value=col_info.get("name", "")).font = _body_font(bold=True, color=PALETTE["accent2"])
        col_map.cell(row=r, column=3, value=col_info.get("type", "")).font = _body_font(color="555555")
        dc = col_map.cell(row=r, column=4, value=col_info.get("description", ""))
        dc.font      = _body_font()
        dc.alignment = Alignment(wrap_text=True)
        for c in range(2, 5):
            col_map.cell(row=r, column=c).fill   = _fill(stripe)
            col_map.cell(row=r, column=c).border = _thin_border()
        col_map.row_dimensions[r].height = 18

    wb.save(str(xlsx_path))
    STATE.log_agent_progress(agent_id, f"Saved {len(df)} rows → {xlsx_path.name}")
    return xlsx_path

def setup_dashboard_routes(app: Flask):
    @app.route("/")
    def index():
        return render_template_string(
            DASHBOARD_HTML,
            metrics_history_len=CONFIG["metrics_history_len"],
        )
    
    @app.route("/generator")
    def generator_page():
        return render_template_string(GENERATOR_HTML)

    @app.route("/api/generate", methods=["POST"])
    def api_generate():
        try:
            data = flask_request.json
            prompt = data.get("prompt")
            use_scraping = data.get("scrape", False)
            
            if not prompt:
                return jsonify({"success": False, "error": "No prompt"}), 400

            client = build_nim_client()
            agent_id = "GEN-" + str(uuid.uuid4())[:4]
            
            def run_task():
                STATE.add_agent(agent_id, "Generating: " + prompt[:20])
                try:
                    run_dataset_generation(prompt, agent_id, client, use_scraping)
                    STATE.finish_agent(agent_id, True, "Dataset generated successfully.")
                except Exception as e:
                    STATE.finish_agent(agent_id, False, str(e))

            threading.Thread(target=run_task, daemon=True).start()
            return jsonify({"success": True, "agent_id": agent_id})
        except Exception as e:
            return jsonify({"success": False, "error": str(e)}), 500
    
    @app.route("/api/state")
    def api_state():
        return jsonify(STATE.snapshot())

    @app.route("/api/metrics")
    def api_metrics():
        return jsonify(list(STATE.metrics_history))


