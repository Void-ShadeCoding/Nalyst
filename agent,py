def _try_gpu_metrics() -> dict:
    try:
        import GPUtil
        gpus = GPUtil.getGPUs()
        if not gpus:
            return {}
        g = gpus[0]
        return {
            "gpu_load_pct":   round(g.load * 100, 1),
            "vram_used_mb":   round(g.memoryUsed, 1),
            "vram_total_mb":  round(g.memoryTotal, 1),
            "vram_pct":       round(g.memoryUtil * 100, 1),
            "gpu_temp_c":     round(g.temperature, 1),
        }
    except Exception:
        return {}


def collect_metrics() -> dict:
    cpu_pct     = psutil.cpu_percent(interval=1)
    ram         = psutil.virtual_memory()
    disk        = psutil.disk_usage(".")
    temps       = {}

    try:
        raw_temps = psutil.sensors_temperatures()
        for key in ("coretemp", "cpu_thermal", "cpu-thermal", "k10temp", "acpitz"):
            if key in raw_temps and raw_temps[key]:
                temps["cpu_temp_c"] = round(raw_temps[key][0].current, 1)
                break
    except Exception:
        pass

    metrics = {
        "timestamp":       datetime.utcnow().isoformat(),
        "cpu_pct":         round(cpu_pct, 1),
        "cpu_temp_c":      temps.get("cpu_temp_c"),
        "ram_used_mb":     round(ram.used / 1024 / 1024, 1),
        "ram_total_mb":    round(ram.total / 1024 / 1024, 1),
        "ram_pct":         round(ram.percent, 1),
        "disk_used_gb":    round(disk.used / 1024 ** 3, 2),
        "disk_total_gb":   round(disk.total / 1024 ** 3, 2),
        "disk_pct":        round(disk.percent, 1),
        "active_agents":   len(STATE.active_agents),
    }
    metrics.update(_try_gpu_metrics())
    return metrics


def metrics_loop(socketio: SocketIO):
    while True:
        try:
            m = collect_metrics()
            STATE.metrics_history.append(m)
            socketio.emit("metrics", m)
            state_snap = STATE.snapshot()
            socketio.emit("state", state_snap)
        except Exception as exc:
            log.warning(f"Metrics collection error: {exc}")
        time.sleep(CONFIG["metrics_interval_seconds"])


